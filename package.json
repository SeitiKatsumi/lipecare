{
  "name": "lipecare",
  "version": "0.1.21",
  "deployNumber": 25,
  "private": true,
  "description": "LipeCare monorepo for clinical patient monitoring.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces",
    "dev:portal": "npm run dev -w @lipecare/portal",
    "dev:web": "npm run dev -w @lipecare/web",
    "dev:api": "npm run dev -w @lipecare/api",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "prisma:generate": "npm run prisma:generate -w @lipecare/api",
    "prisma:migrate": "npm run prisma:migrate -w @lipecare/api"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
